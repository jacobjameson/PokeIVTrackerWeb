# Copy this to .env and fill in your Firebase project credentials.
# Get these from: Firebase Console → Project Settings → Your apps → SDK setup and configuration
# Firebase config values are safe to expose publicly — security is enforced by Firestore rules.

VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
